{
  "name": "claude-debug-copilot",
  "version": "2.1.0",
  "description": "Evidence-first diagnostic system for backend failures with interactive integration website",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --coverage --ci --coverageReporters=text --coverageReporters=lcov",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=e2e --coverage",
    "start": "node src/server.js"
  },
  "keywords": ["debugging", "evidence-first", "backend-failures", "orchestration"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "fs-extra": "^11.3.4",
    "jest": "^29.7.0",
    "puppeteer": "^24.38.0"
  }
}
