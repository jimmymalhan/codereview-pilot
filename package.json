{
  "name": "codereview-pilot",
  "version": "3.0.0",
  "description": "Production-ready incident diagnosis system with Apple-grade UI",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --coverage --ci --coverageReporters=text --coverageReporters=lcov",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=e2e --coverage",
    "start": "node src/server.js"
  },
  "keywords": [
    "incident-diagnosis",
    "evidence-first",
    "root-cause-analysis",
    "backend-debugging",
    "production-ready"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "fs-extra": "^11.3.4",
    "jest": "^29.7.0",
    "puppeteer": "^24.38.0"
  },
  "optionalDependencies": {
    "chart.js": "^4.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
