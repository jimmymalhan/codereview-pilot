# Code Review Pilot - Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Required: GitHub token for gh cli (default for all agents)
# GH_TOKEN=ghp_xxx
# Or: GITHUB_TOKEN=ghp_xxx

# Per-agent GitHub identities (optional - for multiple contributors on PRs)
# Create machine user accounts, generate PATs, add as collaborators.
# When set, each agent posts PR comments as its own GitHub identity.
# See .claude/skills/github-agent-identities/SKILL.md

# GH_TOKEN_CODERREVIEWER=ghp_xxx
# GH_TOKEN_APIVALIDATOR=ghp_xxx
# GH_TOKEN_EVIDENCE_REVIEWER=ghp_xxx
# GH_TOKEN_QA_REVIEWER=ghp_xxx
# GH_TOKEN_CRITIC=ghp_xxx
# GH_TOKEN_REVIEW_ALWAYS=ghp_xxx
# GH_TOKEN_REVIEW_STYLE=ghp_xxx
# GH_TOKEN_CI=ghp_xxx
# GH_TOKEN_LINT=ghp_xxx
# GH_TOKEN_REVIEW_PROJECT=ghp_xxx

# API keys for diagnosis pipeline (if using cloud APIs)
# ANTHROPIC_API_KEY=sk-ant-xxx
