{
  "version": "1.0",
  "projectName": "Code Review Pilot",
  "description": "Evidence-first diagnostic system with production-grade reliability",

  "environment": {
    "NODE_ENV": "development",
    "PORT": "3000",
    "TIMEOUT_MS": "60000",
    "MAX_RETRIES": "2",
    "COVERAGE_THRESHOLD": "60",
    "AUTO_MERGE": "true",
    "ULTRA_AUTO": "true",
    "RUN_TO_VEGAS": "true"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/branch-aware-permissions.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/update-confidence.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-edits.sh"
          }
        ]
      }
    ]
  },

  "subagents": {
    "description": "Core agents (keep to 3-5 total for efficiency)",
    "core": [
      {
        "name": "Explore",
        "model": "haiku",
        "role": "Codebase search and discovery (read-only)",
        "tools": ["Glob", "Grep", "Read"],
        "skills": ["project-guardrails", "evidence-proof", "router", "retriever", "plan-and-execute", "execution-agent", "structured-logging", "audit-trail", "cost-guardrails"],
        "capabilities": [
          "Find files by pattern (e.g., 'src/**/*.js')",
          "Search code for keywords (e.g., 'API endpoints')",
          "Answer questions about codebase structure"
        ],
        "constraints": ["Cannot edit files", "Cannot run commands", "Cannot execute code"]
      },
      {
        "name": "Plan",
        "model": "sonnet",
        "role": "Research and plan design approaches",
        "tools": ["Glob", "Grep", "Read", "WebFetch", "WebSearch"],
        "skills": ["project-guardrails", "evidence-proof", "e2e-orchestrator", "plan-and-execute", "execution-agent", "agent-task-assignment", "github-agent-identities", "full-cycle-automation", "branch-cleanup", "ultra-automation", "auto-merge", "dag-executor", "token-budget", "consensus-resolver", "consensus-gates", "user-feedback-to-skillset", "repository-audit-to-skillset", "pr-comments-live", "parallel-execution", "naming-convention-product", "handoff-protocol", "failure-taxonomy", "explainability", "graceful-degradation", "time-bounded-run", "heartbeat-monitor", "dead-man-switch", "cron-awareness", "feedback-loop", "structured-logging", "audit-trail", "project-structure", "idea-to-production", "run-the-business", "multi-pr-coordinator", "cost-guardrails"],
        "capabilities": [
          "Explore codebase during Plan Mode",
          "Design implementation approaches",
          "Identify risks and unknowns",
          "Create detailed work breakdowns"
        ],
        "constraints": ["Cannot edit code", "Cannot commit", "Proceed automatically—never wait for user"]
      },
      {
        "name": "General-Purpose",
        "model": "haiku",
        "role": "Code writing and test execution",
        "tools": ["All"],
        "skills": ["evidence-proof", "backend-reliability", "ui-quality", "frontend-engineer", "backend-engineer", "qa-engineer", "pr-push-merge", "execution-agent", "agent-task-assignment", "github-agent-identities", "full-cycle-automation", "branch-cleanup", "dag-executor", "token-budget", "handoff-protocol", "failure-taxonomy", "explainability", "graceful-degradation", "property-based-testing", "secrets-scan", "reversibility", "circuit-breaker", "retry-with-backoff", "time-bounded-run", "heartbeat-monitor", "dead-man-switch", "feedback-loop", "feedback-log", "structured-logging", "audit-trail", "auto-merge", "skills-self-update", "five-agent-verification", "ten-pass-verification", "consensus-resolver", "consensus-gates", "user-feedback-to-skillset", "repository-audit-to-skillset", "pr-comments-live", "parallel-execution", "naming-convention-product", "self-fix", "conflict-resolution", "multi-pr-coordinator", "cost-guardrails"],
        "capabilities": [
          "Implement approved plans",
          "Write and run tests",
          "Commit changes with messages",
          "Verify critical workflows"
        ],
        "constraints": ["Proceed from plan automatically", "Cannot skip tests", "Never wait for user to run, update, or accept"]
      }
    ],
    "optional": [
      {
        "name": "CodeReviewer",
        "model": "sonnet",
        "role": "Code quality, security, performance review",
        "tools": ["Read", "Grep", "Glob"],
        "skills": ["project-guardrails", "evidence-proof", "consensus-resolver", "explainability", "confidence-decay", "anomaly-detection", "critic", "backend-reliability", "ui-quality", "skills-self-update", "five-agent-verification", "ten-pass-verification"],
        "use_when": "Need parallel code review while coding",
        "phase": 3
      },
      {
        "name": "APIValidator",
        "model": "haiku",
        "role": "API contract testing and endpoint verification",
        "tools": ["Bash", "Read", "Grep"],
        "skills": ["backend-reliability", "verifier", "evidence-proof", "feedback-log", "five-agent-verification"],
        "use_when": "Phase 2 or 3; spawn with CodeReviewer, EvidenceReviewer, QAReviewer, Critic in parallel",
        "phase": 2
      },
      {
        "name": "EvidenceReviewer",
        "model": "haiku",
        "role": "Verify file:line citations, no invented APIs/fields",
        "tools": ["Read", "Grep", "Glob"],
        "skills": ["evidence-proof", "retriever", "verifier", "five-agent-verification"],
        "use_when": "Phase 3 ten-pass pass 3; spawn with CodeReviewer, APIValidator, QAReviewer, Critic in parallel",
        "phase": 3
      },
      {
        "name": "frontend-engineer",
        "model": "haiku",
        "role": "UI design and interaction specialist",
        "tools": ["Read","Write","Edit","Glob","Grep"],
        "skills": ["frontend-engineer", "ui-quality", "evidence-proof", "ui-premium-checklist", "feedback-log", "backend-full-checklist"],
        "use_when": "Creating or reviewing frontend features",
        "phase": 2
      },
      {
        "name": "backend-engineer",
        "model": "haiku",
        "role": "Server-side reliability and API specialist",
        "tools": ["Read","Write","Edit","Glob","Grep"],
        "skills": ["backend-engineer", "backend-reliability", "evidence-proof", "backend-full-checklist", "feedback-log"],
        "use_when": "Creating or reviewing backend features",
        "phase": 2
      },
      {
        "name": "qa-engineer",
        "model": "haiku",
        "role": "Test plan and validation specialist",
        "tools": ["Read","Write","Edit","Run","Glob","Grep"],
        "skills": ["qa-engineer", "evidence-proof", "property-based-testing", "confidence-decay", "anomaly-detection", "failure-taxonomy", "critic", "pr-push-merge", "feedback-log", "skills-self-update", "five-agent-verification", "ten-pass-verification"],
        "use_when": "Defining or verifying proof plans",
        "phase": 3
      },
      {
        "name": "LiveWatchdog",
        "model": "haiku",
        "role": "Poll CI, deploy, health. On error → error-detector → fix-pr-creator",
        "tools": ["Bash", "Read", "Grep"],
        "skills": ["live-watchdog", "error-detector", "fix-pr-creator", "ultra-automation", "auto-merge", "failure-taxonomy", "circuit-breaker", "retry-with-backoff", "cron-awareness", "structured-logging", "audit-trail", "cost-guardrails"],
        "use_when": "Run-the-business mode; live monitoring after execute",
        "phase": 2
      },
      {
        "name": "FixAgent",
        "model": "haiku",
        "role": "Apply fixes when CI red. Self-fix loop until green.",
        "tools": ["All"],
        "skills": ["self-fix", "conflict-resolution", "circuit-breaker", "retry-with-backoff", "feedback-loop", "failure-taxonomy", "handoff-protocol", "reversibility", "explainability", "evidence-proof", "backend-reliability", "ui-quality", "structured-logging", "audit-trail", "cost-guardrails"],
        "use_when": "fix-pr-creator spawns; CI red needs fix",
        "phase": 2
      },
      {
        "name": "RebaseResolver",
        "model": "haiku",
        "role": "Rebase dependent PRs after base merge",
        "tools": ["Bash", "Read", "Edit"],
        "skills": ["rebase-manager", "conflict-resolution"],
        "use_when": "multi-pr-coordinator after base PR merged",
        "phase": 2
      },
      {
        "name": "ChaosTester",
        "model": "haiku",
        "role": "Simulate end users, internal users, engineers. Random tests on UI+backend to generate errors. Iterate on its own; handoff to FixAgent.",
        "tools": ["Bash", "Read", "Grep", "Glob"],
        "skills": ["chaos-tester", "evidence-proof", "error-detector", "time-bounded-run", "heartbeat-monitor", "cost-guardrails"],
        "use_when": "Testing UI + backend with random/fuzz tests; finding errors before release",
        "phase": 3
      }
    ],
    "guidance": "Assign every task to an agent. Spawn optional agents when their phase runs—run in parallel. No minimum task count. Nothing left unassigned or hanging. See agent-task-assignment skill."
  },

  "allowedCommands": [
    "npm install", "npm test", "npm run test:ci", "npm run test:watch",
    "npm run test:e2e", "npm start", "npm run diagnose",
    "git status", "git diff", "git log", "git add", "git commit", "git branch", "git push", "git checkout", "git merge",
    "node src/local-pipeline.js", "node src/run.js",
    "gh pr list", "gh pr view", "gh pr create", "gh pr comment", "gh pr merge", "gh pr close",
    "gh run list", "gh run view"
  ],

  "criticalFiles": [
    "CLAUDE.md", ".claude/CLAUDE.md", ".claude/settings.json",
    "package.json", "src/server.js", "src/local-pipeline.js",
    ".claude/CONFIDENCE_SCORE.md", ".claude/rules/"
  ],

  "mcp": {
    "enabled": true,
    "servers": [
      {
        "name": "claude-ai-context",
        "type": "library-docs",
        "description": "Fetch documentation for libraries"
      }
    ]
  },

  "coverage": {
    "global": 60,
    "branches": 60,
    "functions": 60,
    "lines": 60,
    "statements": 60,
    "exclusions": ["node_modules/", "coverage/", "dist/", "tests/"]
  },

  "rules": [
    "CLAUDE.md - project non-negotiable rules",
    "REVIEW.md - code review guidelines, 10-pass verification",
    ".claude/CLAUDE.md - meta-rules (workflow, memory, subagents)",
    ".claude/rules/guardrails.md - anti-hallucination standards",
    ".claude/rules/testing.md - test requirements and coverage",
    ".claude/rules/confidence.md - confidence scoring rubric",
    ".claude/rules/backend.md - reliability and error handling",
    ".claude/rules/ui.md - design and UX standards",
    ".claude/rules/ui-proof.md - evidence requirements for UI work",
    ".claude/rules/backend-proof.md - evidence requirements for backend work",
    ".claude/rules/ai-ml.md - machine learning best practices",
    ".claude/rules/agentic-ai.md - multi-agent orchestration standards",
    ".claude/rules/rag.md - retrieval-augmented generation quality"
  ],

  "documentation": {
    "README.md": "Problem, quick start, features, integration",
    ".claude/SKILLSETS.md": "Skill index; all governance in skills",
    "REVIEW.md": "Code review guidelines; ten-pass passes 6,7,10",
    "CLAUDE.md": "Project rules, workflow, output contract",
    ".claude/CLAUDE.md": "Meta-rules, Plan Mode, memory, subagents",
    "CHANGELOG.md": "Session-by-session change log",
    ".claude/CONFIDENCE_SCORE.md": "Truth ledger (see confidence-score skill)",
    ".claude/rules/": "Standards for specific concerns"
  },

  "branchPermissions": {
    "main": {
      "autoAcceptEdits": false,
      "noPermissionPrompts": false,
      "description": "No direct commits. All changes through feature/* branches. Create branch first."
    },
    "feature/*": {
      "autoAcceptEdits": true,
      "noPermissionPrompts": true,
      "description": "Any feature branch - auto-accept end-to-end, run the business without permission prompts"
    },
    "feature/integration-website": {
      "autoAcceptEdits": true,
      "noPermissionPrompts": true,
      "description": "Feature branch - auto-accept edits during development"
    },
    "feature/paperclip-integration": {
      "autoAcceptEdits": true,
      "noPermissionPrompts": true,
      "description": "Feature branch - auto-accept edits during development"
    },
    "feature/skillsets-and-fe-be-skills": {
      "autoAcceptEdits": true,
      "noPermissionPrompts": true,
      "description": "Feature branch - auto-accept end-to-end"
    }
  }
}
